{
  "name": "tour-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Headless onboarding and product tour library for React",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiDex/tour-kit.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "example:vite": "pnpm --filter vite-tour-kit-demo dev",
    "example:next": "pnpm --filter next-tour-kit-demo dev",
    "size": "pnpm --filter @tour-kit/bundle-check check",
    "size:why": "pnpm --filter @tour-kit/bundle-check check:why",
    "bench": "turbo run bench",
    "bench:core": "pnpm --filter @tour-kit/core vitest bench"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@changesets/cli": "^2.30.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^27.3.0",
    "turbo": "^2.8.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "react-router": ">=7.12.0",
      "preact": ">=10.28.2"
    },
    "ignoredBuiltDependencies": ["esbuild", "sharp"],
    "onlyBuiltDependencies": ["@biomejs/biome"]
  }
}
