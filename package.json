{
  "name": "tour-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Headless onboarding and product tour library for React",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiDex/tour-kit.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "example:vite": "pnpm --filter vite-tour-kit-demo dev",
    "example:next": "pnpm --filter next-tour-kit-demo dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@changesets/cli": "^2.29.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@vitest/coverage-v8": "^4.0.16",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.3.0",
    "turbo": "^2.7.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {},
    "ignoredBuiltDependencies": ["esbuild", "sharp"],
    "onlyBuiltDependencies": ["@biomejs/biome"]
  }
}
