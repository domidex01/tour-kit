{
  "name": "@tour-kit/scheduling",
  "version": "0.1.0",
  "description": "Time-based scheduling utilities for TourKit tours and announcements",
  "author": "Tour Kit Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/DomiDex/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiDex/tour-kit.git",
    "directory": "packages/scheduling"
  },
  "bugs": {
    "url": "https://github.com/DomiDex/tour-kit/issues"
  },
  "keywords": ["react", "scheduling", "timezone", "business-hours", "tour-kit"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@tour-kit/license": ">=0.0.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tour-kit/license": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
