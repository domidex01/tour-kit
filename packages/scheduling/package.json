{
  "name": "@tour-kit/scheduling",
  "version": "0.9.0",
  "description": "React scheduling hooks with IANA timezones, business hours, blackouts & recurring patterns — show UI on a schedule.",
  "author": "Tour Kit Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/domidex01/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domidex01/tour-kit.git",
    "directory": "packages/scheduling"
  },
  "bugs": {
    "url": "https://github.com/domidex01/tour-kit/issues"
  },
  "keywords": [
    "scheduling",
    "react-scheduling",
    "schedule",
    "timezone",
    "iana-timezone",
    "business-hours",
    "blackout",
    "recurring",
    "cron",
    "time-window",
    "dst",
    "react-hooks",
    "tour-kit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tour-kit/license": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-axe": "catalog:"
  }
}
