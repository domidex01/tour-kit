{
  "name": "@tour-kit/analytics",
  "version": "0.1.5",
  "description": "Plugin-based analytics for product tours and onboarding — ship tour engagement events to PostHog, Mixpanel, Amplitude, Google Analytics 4, or any custom backend",
  "author": "Tour Kit Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/domidex01/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domidex01/tour-kit.git",
    "directory": "packages/analytics"
  },
  "bugs": {
    "url": "https://github.com/domidex01/tour-kit/issues"
  },
  "keywords": [
    "react",
    "analytics",
    "product-analytics",
    "event-tracking",
    "tour-analytics",
    "onboarding-analytics",
    "posthog",
    "mixpanel",
    "amplitude",
    "google-analytics",
    "ga4",
    "plugin",
    "user-engagement",
    "funnel-tracking",
    "tour-kit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./posthog": {
      "import": {
        "types": "./dist/plugins/posthog.d.ts",
        "default": "./dist/plugins/posthog.js"
      },
      "require": {
        "types": "./dist/plugins/posthog.d.cts",
        "default": "./dist/plugins/posthog.cjs"
      }
    },
    "./mixpanel": {
      "import": {
        "types": "./dist/plugins/mixpanel.d.ts",
        "default": "./dist/plugins/mixpanel.js"
      },
      "require": {
        "types": "./dist/plugins/mixpanel.d.cts",
        "default": "./dist/plugins/mixpanel.cjs"
      }
    },
    "./amplitude": {
      "import": {
        "types": "./dist/plugins/amplitude.d.ts",
        "default": "./dist/plugins/amplitude.js"
      },
      "require": {
        "types": "./dist/plugins/amplitude.d.cts",
        "default": "./dist/plugins/amplitude.cjs"
      }
    },
    "./google-analytics": {
      "import": {
        "types": "./dist/plugins/google-analytics.d.ts",
        "default": "./dist/plugins/google-analytics.js"
      },
      "require": {
        "types": "./dist/plugins/google-analytics.d.cts",
        "default": "./dist/plugins/google-analytics.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tour-kit/core": "workspace:*",
    "@tour-kit/license": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@amplitude/analytics-browser": {
      "optional": true
    },
    "mixpanel-browser": {
      "optional": true
    },
    "posthog-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@amplitude/analytics-browser": "^2.36.7",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@tour-kit/tsconfig": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "mixpanel-browser": "^2.75.0",
    "posthog-js": "^1.362.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
