{
  "name": "@tour-kit/ai",
  "version": "0.0.5",
  "description": "AI chat widget for React with RAG, CAG, and tour context — drop-in conversational assistant powered by Vercel AI SDK with vector search and tour-aware system prompts",
  "author": "Tour Kit Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/domidex01/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domidex01/tour-kit.git",
    "directory": "packages/ai"
  },
  "bugs": {
    "url": "https://github.com/domidex01/tour-kit/issues"
  },
  "keywords": [
    "react",
    "ai",
    "ai-chat",
    "ai-chatbot",
    "ai-assistant",
    "chat-widget",
    "rag",
    "retrieval-augmented-generation",
    "cag",
    "context-augmented-generation",
    "vector-search",
    "embeddings",
    "vercel-ai-sdk",
    "openai",
    "ai-sdk",
    "llm",
    "in-app-chat",
    "support-bot",
    "onboarding",
    "tour-kit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless.d.ts",
        "default": "./dist/headless.js"
      },
      "require": {
        "types": "./dist/headless.d.cts",
        "default": "./dist/headless.cjs"
      }
    },
    "./tailwind": {
      "import": {
        "types": "./dist/tailwind/index.d.ts",
        "default": "./dist/tailwind/index.js"
      },
      "require": {
        "types": "./dist/tailwind/index.d.cts",
        "default": "./dist/tailwind/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "styles"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tour-kit/core": "workspace:*",
    "@tour-kit/license": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^2.0.0",
    "ai": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/provider": "^2.0.0",
    "@ai-sdk/react": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "ai": "~5.0.157",
    "jsdom": "^29.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
