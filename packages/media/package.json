{
  "name": "@tour-kit/media",
  "version": "0.1.1",
  "description": "Embedded video and media support for TourKit tours and announcements",
  "author": "Tour Kit Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/DomiDex/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiDex/tour-kit.git",
    "directory": "packages/media"
  },
  "bugs": {
    "url": "https://github.com/DomiDex/tour-kit/issues"
  },
  "keywords": ["react", "video", "media", "youtube", "vimeo", "loom", "embed", "tour-kit"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./headless": {
      "import": {
        "types": "./dist/headless.d.ts",
        "default": "./dist/headless.js"
      },
      "require": {
        "types": "./dist/headless.d.cts",
        "default": "./dist/headless.cjs"
      }
    },
    "./styles.css": "./dist/styles/variables.css",
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "restricted",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@tour-kit/license": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@lottiefiles/react-lottie-player": "^3.5.0",
    "@mui/base": "^5.0.0-beta.0"
  },
  "peerDependenciesMeta": {
    "@lottiefiles/react-lottie-player": {
      "optional": true
    },
    "@mui/base": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lottiefiles/react-lottie-player": "^3.5.0",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
