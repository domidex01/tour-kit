{
  "name": "@tour-kit/license",
  "version": "0.0.1",
  "description": "License validation for Tour Kit premium features",
  "author": "Tour Kit Team",
  "license": "MIT",
  "homepage": "https://github.com/DomiDex/tour-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiDex/tour-kit.git",
    "directory": "packages/license"
  },
  "bugs": {
    "url": "https://github.com/DomiDex/tour-kit/issues"
  },
  "keywords": ["react", "license", "jwt", "tour-kit", "premium"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || >=19.2.0",
    "react-dom": "^18.0.0 || >=19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.0.16",
    "jsdom": "^27.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
