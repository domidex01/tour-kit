{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "size": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "bench": {
      "dependsOn": ["build"],
      "outputs": ["benchmark-results.json"]
    },
    "e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
